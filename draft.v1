let current = 0;
let score = 0;
let answered = [];

function init() {
  renderQuestionNav();
  renderQuiz();
  updateStats();
}

function renderQuestionNav() {
  const nav = document.getElementById('questionNav');
  nav.innerHTML = questions.map((_, i) =>
    `<div class="nav-dot" onclick="goToQuestion(${i})" data-idx="${i}">${i + 1}</div>`
  ).join('');
}

function updateQuestionNav() {
  document.querySelectorAll('.nav-dot').forEach((dot, i) => {
    dot.classList.remove('current', 'answered', 'wrong');
    if (i === current) dot.classList.add('current');
    if (answered[i] !== undefined) {
      if (answered[i] === questions[i].correct) {
        dot.classList.add('answered');
      } else {
        dot.classList.add('answered', 'wrong');
      }
    }
  });
}

function goToQuestion(idx) {
  current = idx;
  renderQuiz();
  updateQuestionNav();
}

function renderQuiz() {
  const area = document.getElementById('quizArea');
  const q = questions[current];
  const userAns = answered[current];

  const letters = ['A', 'B', 'C', 'D', 'E'];

  let optsHtml = q.opts.map((opt, i) => {
    let cls = 'option';
    if (userAns !== undefined) {
      cls += ' disabled';
      if (i === q.correct) cls += ' correct';
      else if (i === userAns) cls += ' wrong';
    }
    return `<div class="${cls}" onclick="selectOption(${i})" data-idx="${i}" tabindex="0">
      <div class="option-letter">${letters[i]}</div>
      <div class="option-text">${opt}</div>
    </div>`;
  }).join('');

  const isCorrect = userAns === q.correct;
  const explainClass = userAns !== undefined ? (isCorrect ? 'correct' : 'wrong') : '';

  area.innerHTML = `
    <div class="card">
      <div class="card-header">
        <div class="question-number">Soal <span>${current + 1}</span> / ${questions.length}</div>
      </div>
      <p class="question-text">${q.q}</p>
      <div class="options">${optsHtml}</div>
      <div class="explain ${userAns !== undefined ? 'show' : ''} ${explainClass}">
        <div class="explain-label">Penjelasan</div>
        <div class="explain-text">${userAns !== undefined ? q.explain : ''}</div>
      </div>
    </div>
    <div class="nav">
      <button onclick="prevQuestion()" ${current === 0 ? 'disabled' : ''}>← Sebelumnya</button>
      <button class="primary" onclick="nextQuestion()" ${userAns === undefined ? 'disabled' : ''}>
        ${current === questions.length - 1 ? 'Lihat Hasil' : 'Selanjutnya →'}
      </button>
    </div>
    <div class="keyboard-hint">
      <span>Gunakan keyboard:</span>
      <span class="key">A</span>
      <span class="key">B</span>
      <span class="key">C</span>
      <span class="key">D</span>
      <span class="key">E</span>
      <span>untuk menjawab</span>
    </div>
  `;

  updateStats();
  updateQuestionNav();
}

function selectOption(idx) {
  if (answered[current] !== undefined) return;
  answered[current] = idx;
  if (idx === questions[current].correct) {
    score++;
  }
  renderQuiz();
}

function nextQuestion() {
  if (current === questions.length - 1) {
    showResult();
  } else {
    current++;
    renderQuiz();
  }
}

function prevQuestion() {
  if (current > 0) {
    current--;
    renderQuiz();
  }
}

function updateStats() {
  const answeredCount = answered.filter(a => a !== undefined).length;
  const pct = Math.round((answeredCount / questions.length) * 100);

  document.getElementById('currentStat').innerHTML = `${current + 1}<span style="font-size: 16px; color: var(--text-muted);">/${questions.length}</span>`;
  document.getElementById('scoreStat').textContent = score;
  document.getElementById('answeredStat').textContent = answeredCount;
  document.getElementById('progressLabel').textContent = answeredCount === questions.length ? 'Selesai!' : 'Kemajuan';
  document.getElementById('progressPercent').textContent = `${pct}%`;
  document.getElementById('progressFill').style.width = `${pct}%`;
}

function showResult() {
  document.getElementById('quizArea').classList.add('hidden');
  const resultArea = document.getElementById('resultArea');
  resultArea.classList.remove('hidden');

  const pct = Math.round((score / questions.length) * 100);
  const wrong = questions.length - score;

  document.getElementById('scoreText').textContent = score;
  document.getElementById('correctCount').textContent = score;
  document.getElementById('wrongCount').textContent = wrong;
  document.getElementById('accuracy').textContent = `${pct}%`;

  const resultTitle = document.getElementById('resultTitle');
  const resultDesc = document.getElementById('resultDesc');

  if (pct >= 80) {
    resultTitle.textContent = 'Luar Biasa';
    resultDesc.textContent = 'Kamu menguasai materi Manajemen Proyek Perangkat Lunak dengan sangat baik. Pertahankan prestasimu!';
  } else if (pct >= 60) {
    resultTitle.textContent = 'Bagus Sekali';
    resultDesc.textContent = 'Kamu sudah memahami konsep dasar. Terus belajar untuk meningkatkan pemahamanmu.';
  } else {
    resultTitle.textContent = 'Tetap Semangat';
    resultDesc.textContent = 'Jangan menyerah! Review materi dan coba lagi untuk meningkatkan pemahamanmu.';
  }

  document.getElementById('progressFill').style.width = '100%';
  document.getElementById('progressPercent').textContent = '100%';
  document.getElementById('progressLabel').textContent = 'Selesai!';
}

function restartQuiz() {
  current = 0;
  score = 0;
  answered = [];
  document.getElementById('resultArea').classList.add('hidden');
  document.getElementById('quizArea').classList.remove('hidden');
  renderQuiz();
  updateQuestionNav();
}

// Keyboard navigation
document.addEventListener('keydown', (e) => {
  const key = e.key.toUpperCase();

  if (['A', 'B', 'C', 'D', 'E'].includes(key)) {
    const idx = key.charCodeAt(0) - 65;
    if (idx < questions[current].opts.length) {
      selectOption(idx);
      // Auto advance to next question after selecting answer
      setTimeout(() => {
        if (answered[current] !== undefined) {
          nextQuestion();
        }
      }, 300); // Small delay for visual feedback
    }
  }

  if (e.key === 'ArrowRight' && answered[current] !== undefined) {
    nextQuestion();
  }
  if (e.key === 'ArrowLeft') {
    prevQuestion();
  }

  // Enter key to go to next question after answering
  if (e.key === 'Enter' && answered[current] !== undefined) {
    nextQuestion();
  }
});

init();
</script>
</body>
</html>